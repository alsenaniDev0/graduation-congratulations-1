{
    "id": "premium-graduation-congratulations-gender",
    "name": "تهنئة تخرج فاخرة",
    "version": "1.0.0",
    "html": "index.html",
    "css": "style.css",
    "fields": [
        {
            "required": true,
            "key": "gender",
            "defaultValue": "boy",
            "label": "نوع التصميم",
            "type": "select",
            "options": [
                {
                    "value": "boy",
                    "label": "خريج"
                },
                {
                    "value": "girl",
                    "label": "خريجة"
                }
            ]
        },
        {
            "key": "badgeText",
            "type": "text",
            "required": true,
            "defaultValue": "بطاقة تهنئة تخرج",
            "label": "النص العلوي",
            "maxLength": 50
        },
        {
            "key": "batchText",
            "type": "text",
            "required": true,
            "defaultValue": "دفعة 2026",
            "label": "نص الدفعة",
            "maxLength": 40
        },
        {
            "key": "icon",
            "type": "icon",
            "required": true,
            "options": [
                {
                    "label": "🎓",
                    "value": "🎓"
                },
                {
                    "label": "🏆",
                    "value": "🏆"
                },
                {
                    "label": "📜",
                    "value": "📜"
                },
                {
                    "label": "✨",
                    "value": "✨"
                },
                {
                    "label": "🌟",
                    "value": "🌟"
                },
                {
                    "label": "🎉",
                    "value": "🎉"
                }
            ],
            "defaultValue": "🎓",
            "label": "الأيقونة"
        },
        {
            "key": "preTitle",
            "type": "text",
            "required": true,
            "defaultValue": "بكل فخر واعتزاز",
            "label": "النص قبل العنوان",
            "maxLength": 60
        },
        {
            "key": "mainTitle",
            "type": "text",
            "required": true,
            "defaultValue": "نبارك التخرج",
            "label": "العنوان الرئيسي",
            "maxLength": 60
        },
        {
            "key": "message",
            "type": "textarea",
            "required": true,
            "defaultValue": "نبارك لكم هذا الإنجاز الجميل، ونسأل الله أن يكون تخرجكم بداية لمستقبل مشرق مليء بالنجاح والتميّز.",
            "label": "نص التهنئة",
            "minLength": 5,
            "maxLength": 260
        },
        {
            "key": "nameLabel",
            "type": "text",
            "required": true,
            "defaultValue": "الخريج / الخريجة",
            "label": "عنوان الاسم",
            "maxLength": 40
        },
        {
            "key": "names",
            "type": "names",
            "required": true,
            "label": "اسم الخريج / الخريجة",
            "placeholder": "مثال: محمد",
            "separator": " و ",
            "minItems": 1,
            "maxItems": 10
        },
        {
            "key": "degree",
            "type": "text",
            "required": true,
            "defaultValue": "تخرجكم فخرٌ لنا وفرحةٌ لا تُنسى",
            "label": "عبارة الإنجاز",
            "maxLength": 90
        },
        {
            "key": "closing",
            "type": "text",
            "required": true,
            "defaultValue": "ألف مبروك التخرج",
            "label": "العبارة الختامية",
            "maxLength": 70
        }
    ]
}