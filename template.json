{
    "id": "soft-green-graduation-story",
    "name": "تهنئة تخرج خضراء ناعمة",
    "version": "1.0.0",
    "html": "index.html",
    "css": "style.css",
    "settings": {
        "exportable": true,
        "hasAnimation": false,
        "width": 1080,
        "height": 1920,
        "durationSeconds": 5
    },
    "fields": [
        {
            "key": "topText",
            "type": "textarea",
            "required": true,
            "defaultValue": "في العصر أيام يزينها السرور\nوسرور هذا اليوم جدا مختلف",
            "label": "النص العلوي",
            "minLength": 5,
            "maxLength": 140
        },
        {
            "key": "middleText",
            "type": "textarea",
            "required": true,
            "defaultValue": "يسعدنا أن تشاركونا فرحتنا بتخرج",
            "label": "نص قبل الاسم",
            "minLength": 3,
            "maxLength": 120
        },
        {
            "key": "name",
            "type": "text",
            "required": true,
            "label": "اسم الخريج / الخريجة",
            "placeholder": "مثال: سارة",
            "minLength": 2,
            "maxLength": 50
        },
        {
            "key": "bottomText",
            "type": "textarea",
            "required": true,
            "defaultValue": "لقاؤكم المحب يزيد أنساً\nفتقربكم المسرة والسعادة",
            "label": "النص السفلي",
            "minLength": 5,
            "maxLength": 140
        }
    ]
}